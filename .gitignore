# ── Robin: repo-root .gitignore (ships with the fork-ready starter) ──────────
# Goal: keep secrets and rebuildable runtime state out of git, while KEEPING
# your durable knowledge (base/brain/**) tracked. If you point ROBIN_VAULT at a
# directory other than `base/`, update the `base/` paths below to match.

# Secrets & environment (keep the *.example templates tracked)
.env
.env.*
!.env.example
!.env.*.example

# Vault runtime sidecar — rebuildable SQLite index + rendered cache
base/.robin/
**/.robin/

# Node dependencies + build artifacts (the app lives under robin/app)
node_modules/
**/node_modules/
robin/app/**/.next/
robin/app/**/dist/
robin/app/**/.turbo/
robin/app/**/*.tsbuildinfo
robin/app/**/test-results/
robin/app/**/playwright-report/
robin/app/**/.playwright-mcp/
# Rebuildable Playwright fixture index (regenerated by the indexer/test setup)
robin/app/tests/fixtures/vault/.robin/

# Claude Code local state (the shared .claude/ control plane STAYS tracked)
.claude/worktrees/
.claude/skills/*.zip
**/.claude/settings.local.json

# Sensitive personal data — never commit (extend with your own as needed)
base/inbox/contracts/

# Local working clones (durable summaries live in base/brain/repos/)
base/repos/

# Local-only assets served to decks (keep out of the shareable framework)
robin/app/apps/web/public/deck-assets/

# Generated-source sidecars (the canonical output stays tracked)
base/logs/daily/.src/
base/logs/interviews/.live/

# Recordings / audio (not vault content)
*.webm
*.wav
*.mp3
*.m4a
*.ogg
*.flac
*.aac

# Transient runtime / debug state
.playwright-mcp/
.robin-resync
robin-*.png

# OS / editor noise
.DS_Store
**/.DS_Store
*.swp
*.swo
.idea/
.vscode/
