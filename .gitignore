# macOS cruft
.DS_Store
**/.DS_Store

# Editor/IDE
*.swp
*.swo
.idea/
.vscode/

# Node / Python
node_modules/
__pycache__/
*.pyc
.venv/

# Environment files (keep the examples)
.env
.env.*
!.env.example
!.env.*.example

# Robin app build / runtime artifacts (rebuildable)
app/**/.next/
app/**/dist/
app/**/.turbo/
app/**/test-results/
app/**/playwright-report/
app/**/.playwright-mcp/

# Rebuildable Playwright fixture index (regenerated by the indexer/test setup)
app/tests/fixtures/vault/.robin/

# Your vault's runtime sidecar (SQLite index + rendered cache) — wherever ROBIN_VAULT points.
# The kit default vault dir is ./base; adjust if you point ROBIN_VAULT elsewhere.
base/
.robin/

# Recordings / audio (not framework content)
*.webm
*.wav
*.mp3
*.m4a
*.ogg
*.flac
*.aac

# Transient runtime / debug state
.playwright-mcp/
.robin-resync
