# --- Owner / org identity -------------------------------------------------
# Personalizes greetings, prompts, transcript speaker labels, and the about
# page. Leave any of these blank to get a fully generic experience ("You",
# "your AI partner and second brain", etc.).

# The human this brain belongs to (e.g. Alex). Server-side.
ROBIN_OWNER=
# The org/company this brain serves (e.g. ExampleCo). Optional. When set, the
# interviewer persona reads "...second brain at <ORG>". Server-side.
ROBIN_ORG=
# Comma-separated proper nouns to bias live meeting transcription (Deepgram
# keyterms): product names, project codenames, etc. e.g. "Acme,Widget,Foo"
ROBIN_ORG_GLOSSARY=
# Owner label exposed to the browser (chat speaker label). Must be the
# NEXT_PUBLIC_ variant since it is read in a client component; set it to the
# same value as ROBIN_OWNER. Inlined at build time.
NEXT_PUBLIC_ROBIN_OWNER=

# --- Vault ----------------------------------------------------------------
# Robin vault root (absolute path).
ROBIN_VAULT=/absolute/path/to/your/vault

# --- Assistant ------------------------------------------------------------
# ASSISTANT_MODE=stub returns deterministic local responses without Claude CLI.
ASSISTANT_MODE=claude
ASSISTANT_CLAUDE_CWD=/absolute/path/to/your/repo
ASSISTANT_SESSION_FILE=/absolute/path/to/your/vault/.robin/assistant-session.json

# --- Interview voice relay ------------------------------------------------
ROBIN_XAI_MODE=stub
XAI_API_KEY=
INTERVIEW_MODEL=grok-voice-think-fast-1.0
INTERVIEW_VOICE=eve
INTERVIEW_WS_PORT=8401

# --- Meeting transcription ------------------------------------------------
# stub uses fixtures; local uses whisper-node; openai uses OPENAI_API_KEY.
ROBIN_WHISPER_MODE=stub
OPENAI_API_KEY=

# Live meeting STT (in-browser streaming). The /api/meeting/deepgram-token
# route mints short-lived tokens from this key. Get one at
# https://console.deepgram.com.
DEEPGRAM_API_KEY=

# Meeting AI processing (Process step: title, summary, key points, action items,
# speaker naming, conservative transcript cleanup). Runs via OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Native Meeting Recorder boundary.
MEETING_RECORDER_APP_PATH=/Applications/Meeting Recorder.app
MEETING_RECORDER_HELPER_URL=
