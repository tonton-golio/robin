{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": [
    "playwright.config.ts",
    "specs/**/*.ts",
    "helpers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
